NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your production domain — used for auth email redirect links.
# Also set in Supabase dashboard: Authentication > URL Configuration > Site URL
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Resend (email)
RESEND_API_KEY=re_your-resend-key-here

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Web Push (VAPID keys) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:info@tristarpickleball.com

# Cron job secret — set this in Vercel and it will auto-send as Authorization header.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
